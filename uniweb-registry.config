# UniWeb 镜像配置文件
# 所有镜像统一为 name:tag 格式，运行时从本地仓库(REGISTRY_SERVER)拉取
# 搬运脚本(tagPullImage/tagPullAllImage)从上游仓库拉取后推到本地仓库
# 上游仓库地址需包含完整路径（如 nacos/nacos-server:v2.3.2）

# 上游源镜像仓库（仅 tagPullImage/tagPushImage 使用）
UNIWEB_REGISTRY_SERVER=dev.xili.pub:5000

# 基础设施镜像
IMAGE_MYSQL=uw-mydb-mysql:8.4.6
IMAGE_REDIS=redis:8.2.3
IMAGE_RABBITMQ=rabbitmq:4.0.9-management
IMAGE_ELASTICSEARCH=elasticsearch:8.18.8
IMAGE_KIBANA=kibana:8.18.8
IMAGE_NACOS=nacos/nacos-server:v2.3.2
IMAGE_MINIO=minio/minio:RELEASE.2025-09-07T16-13-09Z

# UniWeb 微服务镜像
IMAGE_UW_GATEWAY=uw-gateway:1.1.9
IMAGE_UW_AUTH_CENTER=uw-auth-center:6.1.15
IMAGE_UW_TASK_CENTER=uw-task-center:5.1.6
IMAGE_UW_OPS_CENTER=uw-ops-center:1.1.9
IMAGE_UW_GATEWAY_CENTER=uw-gateway-center:1.1.6
IMAGE_UW_AI_CENTER=uw-ai-center:1.0.0
IMAGE_UW_MYDB_CENTER=uw-mydb-center:3.1.6
IMAGE_UW_MYDB_PROXY=uw-mydb-proxy:3.1.6
IMAGE_UW_TINYURL_CENTER=uw-tinyurl-center:3.1.5
IMAGE_UW_NOTIFY_CENTER=uw-notify-center:1.1.5

# UniWeb 前端镜像
IMAGE_ROOT_PC_UI=root-pc-ui:1.1.53
IMAGE_OPS_PC_UI=ops-pc-ui:1.2.93
IMAGE_ADMIN_PC_UI=admin-pc-ui:1.1.82

# SaaS 镜像
IMAGE_SAAS_BASE_APP=saas-base-app:2.0.158
IMAGE_SAAS_FINANCE_APP=saas-finance-app:2.0.37
IMAGE_SAAS_PC_UI=saas-pc-ui:1.1.8

# 开发服务镜像
IMAGE_GITEA=gitea/gitea:1.26
IMAGE_NEXUS3=sonatype/nexus3:latest
IMAGE_UW_CODE_CENTER=uw-code-center:latest
IMAGE_MIHOMO=metacubex/mihomo:latest
IMAGE_REGISTRY=registry:latest
